{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "crisisiq",
  "compatibility_date": "2026-05-03",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "crisisiq-db",
      "database_id": "local-dev"
    }
  ]
}
